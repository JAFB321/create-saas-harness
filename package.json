{
  "name": "create-saas-harness-repo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for the create-saas-harness CLI and its project template.",
  "license": "MIT",
  "packageManager": "pnpm@9.15.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm --filter create-saas-harness build",
    "cli": "pnpm --filter create-saas-harness start",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "prettier": "^3.8.4",
    "typescript": "^5.9.3"
  }
}
