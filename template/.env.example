# =============================================================================
# {{PROJECT_NAME}} — environment
# The app runs 100% mock-first: with NO keys set, every integration falls back
# to a mock provider (with a warning). Fill these in as you wire real services.
# Copy to .env.local and edit. NEVER commit .env.local.
# =============================================================================

# --- App ---------------------------------------------------------------------
APP_BASE_URL=http://localhost:3000
# Enable dev-only tools (mock outbox viewer, payment simulator). Off in prod.
DEV_TOOLS_ENABLED=true

# --- Supabase ----------------------------------------------------------------
# From your Supabase project settings (or `supabase start` for the local stack).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
# SUPABASE_ACCESS_TOKEN= — personal access token, needed by `pnpm db:types` and CI migrations

# --- Providers (mock-first selectors) ----------------------------------------
# Set by the scaffolder to your scaffold-time choices. Each one falls back to
# "mock" until the matching keys below are present.
PAYMENTS_PROVIDER=mock
EMAIL_PROVIDER=mock
STORAGE_PROVIDER=mock

## >>> payments:stripe
# --- Stripe (if PAYMENTS_PROVIDER=stripe) ------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
## <<< payments:stripe

## >>> payments:mercadopago
# --- MercadoPago (if PAYMENTS_PROVIDER=mercadopago) --------------------------
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=
## <<< payments:mercadopago

## >>> email:resend
# --- Resend (if EMAIL_PROVIDER=resend) ---------------------------------------
RESEND_API_KEY=
EMAIL_FROM="{{PROJECT_NAME}} <onboarding@resend.dev>"
## <<< email:resend

## >>> storage:supabase
# --- Supabase Storage (if STORAGE_PROVIDER=supabase) --------------------------
# Private bucket created by the storage migration. Reuses the Supabase keys above.
STORAGE_BUCKET=uploads
## <<< storage:supabase

## >>> storage:s3
# --- S3-compatible storage (if STORAGE_PROVIDER=s3) ---------------------------
# Works with AWS S3, Cloudflare R2, and MinIO.
# For Cloudflare R2 set S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# For local MinIO set S3_ENDPOINT=http://127.0.0.1:9000
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
## <<< storage:s3
