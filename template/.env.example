# =============================================================================
# {{PROJECT_NAME}} — environment
# The app runs 100% mock-first: with NO keys set, every integration falls back
# to a mock provider (with a warning). Fill these in as you wire real services.
# Copy to .env.local and edit. NEVER commit .env.local.
# =============================================================================

# --- App ---------------------------------------------------------------------
APP_BASE_URL=http://localhost:3000
# Enable dev-only tools (mock outbox viewer, payment simulator). Off in prod.
DEV_TOOLS_ENABLED=true

# --- Supabase ----------------------------------------------------------------
# From your Supabase project settings (or `supabase start` for the local stack).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

# --- Providers (mock-first selectors) ----------------------------------------
# payments: "stripe" | "mercadopago" | "mock". Set by the scaffolder.
PAYMENTS_PROVIDER=mock
# email: "resend" | "mock"
EMAIL_PROVIDER=mock
# storage: "s3" | "mock"  (s3 = any S3-compatible: AWS S3, Cloudflare R2, MinIO)
STORAGE_PROVIDER=mock

# --- Stripe (if PAYMENTS_PROVIDER=stripe) ------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --- MercadoPago (if PAYMENTS_PROVIDER=mercadopago) --------------------------
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# --- Resend (if EMAIL_PROVIDER=resend) ---------------------------------------
RESEND_API_KEY=
EMAIL_FROM="{{PROJECT_NAME}} <onboarding@resend.dev>"

# --- S3-compatible storage (if STORAGE_PROVIDER=s3) --------------------------
# For Cloudflare R2 set S3_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# For local MinIO set S3_ENDPOINT=http://127.0.0.1:9000
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=
